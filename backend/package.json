{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "mkdir -p dist && cp -r src/* dist/",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "prisma:migrate": "echo 'Prisma migration placeholder (V1 in-memory dev store)'",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:generate": "echo 'Prisma generate skipped in this environment'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.8"
  }
}